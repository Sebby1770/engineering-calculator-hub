NEXT_PUBLIC_SITE_URL=https://engineeringcalculatorhub.com

# Ads are hidden unless explicitly enabled.
NEXT_PUBLIC_AD_ENABLED=false
NEXT_PUBLIC_AD_PROVIDER=adsense
NEXT_PUBLIC_AD_PLACEHOLDERS=false
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=
NEXT_PUBLIC_ADSENSE_BANNER_SLOT=
NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT=
NEXT_PUBLIC_ADSENSE_IN_CONTENT_SLOT=
NEXT_PUBLIC_ADSENSE_FOOTER_SLOT=
NEXT_PUBLIC_ADSENSE_BETWEEN_CARDS_SLOT=
NEXT_PUBLIC_EZOIC_BANNER_ID=
NEXT_PUBLIC_EZOIC_SIDEBAR_ID=
NEXT_PUBLIC_EZOIC_IN_CONTENT_ID=
NEXT_PUBLIC_EZOIC_FOOTER_ID=
NEXT_PUBLIC_EZOIC_BETWEEN_CARDS_ID=
NEXT_PUBLIC_MEDIAVINE_SITE_ID=

# Stripe Checkout is hidden unless enabled and configured.
NEXT_PUBLIC_STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Supabase (server-only — NEVER prefix these with NEXT_PUBLIC_).
# Used for the donation log (written by the Stripe webhook) and the feedback form.
# Copy from: Supabase Dashboard -> project "engineering-calculator-hub" -> Settings -> API.
# SUPABASE_URL looks like https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY is the "service_role" secret key.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
